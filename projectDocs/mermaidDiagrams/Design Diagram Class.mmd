    %% Dominio Studente
    style AnagraficaLaureando fill: #7acff5, stroke: black, stroke-width: 2px
    style CarrieraLaureando fill: #7acff5, stroke: black, stroke-width: 2px
    style CarrieraLaureandoInformatica fill: #7acff5, stroke: black, stroke-width: 2px
    style Esame fill: #7acff5, stroke: black, stroke-width: 2px
    style EsameInformatica fill: #7acff5, stroke: black, stroke-width:2\px
    
